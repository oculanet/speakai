# SpeakEasy AI - Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to source control.

# ─────────────────────────────────────────────────────────────────────────────
# AI API Configuration
# Choose ONE provider and set the corresponding key.
# ─────────────────────────────────────────────────────────────────────────────

# Option 1 – HuggingFace Inference API (free tier available)
# Docs: https://huggingface.co/docs/api-inference
EXPO_PUBLIC_AI_PROVIDER=huggingface
EXPO_PUBLIC_AI_API_KEY=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Option 2 – OpenAI API
# Docs: https://platform.openai.com/docs
# EXPO_PUBLIC_AI_PROVIDER=openai
# EXPO_PUBLIC_AI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─────────────────────────────────────────────────────────────────────────────
# Speech-to-Text (optional – used for microphone transcription)
# Leave blank to disable the microphone button.
# ─────────────────────────────────────────────────────────────────────────────

# HuggingFace Whisper model is used by default (same key as above).
# If you want to use OpenAI Whisper instead, set a separate key here:
# EXPO_PUBLIC_WHISPER_API_KEY=sk-xxxxxxxx
